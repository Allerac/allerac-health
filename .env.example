# PostgreSQL
POSTGRES_DB=allerac_health
POSTGRES_USER=allerac
POSTGRES_PASSWORD=your_secure_password_here

# Redis (internal only — no host port exposed)
REDIS_URL=redis://redis:6379/0

# InfluxDB
INFLUXDB_DB=health_metrics
INFLUXDB_USER=allerac
INFLUXDB_PASSWORD=your_secure_password_here

# Backend Security
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-minimum-32-characters
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=32-byte-key-for-encrypting-garmin-creds

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3002
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-key

# Cloudflare Tunnel (optional — required to expose health.allerac.ai publicly)
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels
# Then configure public hostnames:
#   health.allerac.ai     → http://localhost:3002
#   health-api.allerac.ai → http://localhost:8000  (optional)
HEALTH_TUNNEL_TOKEN=

# allerac-one integration (optional)
# Set this to the same value as SECRET_KEY in your allerac-one .env
# When configured, allerac-one can call the health API on behalf of its users.
ALLERAC_ONE_SECRET_KEY=
